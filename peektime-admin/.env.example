# ECR
ECR_REGISTRY={새계정ID}.dkr.ecr.ap-northeast-2.amazonaws.com

# MySQL (API EC2 내부 IP로 접근)
DATASOURCE_URL=jdbc:mysql://{API EC2 내부 IP}:3306/peektime?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DATASOURCE_USERNAME=
DATASOURCE_PASSWORD=

# Admin 계정
ADMIN_USERNAME=
ADMIN_PASSWORD=

# API 서버
API_BASE_URL=http://{API EC2 내부 IP}

# Gemini
GEMINI_API_KEY=
