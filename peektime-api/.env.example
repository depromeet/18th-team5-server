# ===========================================
# PeekTime API 환경변수
# ===========================================
# 이 파일을 복사해서 .env로 만들고 실제 값을 채우세요
# cp .env.example .env

# 데이터베이스 (prod 환경)
DB_URL=jdbc:mysql://localhost:3306/peektime
DB_USERNAME=
DB_PASSWORD=

# AWS S3
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=

# ECR (배포용)
ECR_REGISTRY=
IMAGE_TAG=latest